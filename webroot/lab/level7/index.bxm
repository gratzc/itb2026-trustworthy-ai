<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>Lab Level 7 — ITB AI Safety</title>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700;1,9..40,400&amp;family=Outfit:wght@600;700;800&amp;display=swap" rel="stylesheet" />
	<link rel="stylesheet" href="/static/itb-chat.css" />
</head>
<body>
	<div class="page">
		<header class="brand">
			<div class="brand-badge">AI Safety Lab · Level 7</div>
			<h1>Simulated human review</h1>
			<p class="tagline">Visible text is scanned for obvious injection; <strong>raw</strong> input (including hidden Unicode) still reaches the model.</p>
			<div class="meta">
				<span><a href="/lab/">Lab hub</a></span>
				<span><a href="/lab/level6/">← Level 6</a></span>
				<span><a href="/lab/">Hub</a></span>
			</div>
		</header>

		<p class="lab-scenario">Plain attacks may show a “human redacted” message. For authorized demos, researchers use tools that hide instructions in Unicode (e.g. “ASCII smuggler” class tools). Educational context only — see <a href="https://embracethered.com/blog/ascii-smuggler/">ASCII smuggler write-up</a>. Paste encoded payloads from your tool of choice; the server forwards the full raw string to Gemini while the human gate checks a stripped “visible” view.</p>
		<div id="lab-hints" class="lab-hints" hidden>
			<strong>Presenter hint:</strong> Show visible “ignore previous…” blocked, then invisible payload + innocent visible prefix succeeding. Close with “don’t put secrets in the model context.”
		</div>

		<section class="chat-shell" aria-label="Level 7 chat">
			<div class="chat-head">
				<span class="chat-head-dot" aria-hidden="true"></span>
				<h2>Boxton · Level 7</h2>
				<span>HITL simulation</span>
			</div>
			<div id="messages" class="messages" role="log" aria-live="polite" aria-relevant="additions"></div>
			<form id="composer" class="composer" autocomplete="off">
				<input type="text" id="message" name="message" placeholder="Visible question — or paste smuggled Unicode after encoding…" maxlength="2000" required />
				<button type="submit" id="send">Send</button>
			</form>
		</section>

		<p class="foot"><a href="/lab/level6/">← Level 6</a> · <a href="/lab/">Lab hub</a></p>
	</div>

	<script>
	(function () {
		var messagesEl = document.getElementById("messages");
		var form = document.getElementById("composer");
		var input = document.getElementById("message");
		var sendBtn = document.getElementById("send");
		var hintsEl = document.getElementById("lab-hints");
		if (hintsEl && new URLSearchParams(location.search).get("hints") === "1") hintsEl.hidden = false;

		function escapeHtml(s) {
			var div = document.createElement("div");
			div.textContent = s;
			return div.innerHTML;
		}

		function linkify(text) {
			var escaped = escapeHtml(text);
			return escaped.replace(/(https?:\/\/[^\s<]+)/g, function (url) {
				return '<a href="' + url + '" target="_blank" rel="noopener noreferrer">' + url + "</a>";
			});
		}

		function appendBubble(role, html) {
			var div = document.createElement("div");
			div.className = "msg " + role;
			var label = role === "bot" ? "Boxton" : "You";
			div.innerHTML = '<div class="label">' + label + "</div><div class=\"body\">" + html + "</div>";
			messagesEl.appendChild(div);
			messagesEl.scrollTop = messagesEl.scrollHeight;
		}

		appendBubble("bot", linkify("Level 7: If a human reviewer saw obvious jailbreak text, they’d reject it — this lab simulates that on visible text. Hidden Unicode can still reach me. Use only in sanctioned demos."));

		form.addEventListener("submit", function (e) {
			e.preventDefault();
			var text = (input.value || "").trim();
			if (!text) return;

			appendBubble("user", escapeHtml(text));
			input.value = "";
			sendBtn.disabled = true;

			fetch("api/chat.bxm", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ message: text })
			})
				.then(function (r) { return r.json().then(function (data) { return { ok: r.ok, data: data }; }); })
				.then(function (res) {
					if (!res.ok || (res.data && res.data.error)) {
						appendBubble("bot", escapeHtml((res.data && res.data.error) || "Something went wrong. Try again."));
						return;
					}
					appendBubble("bot", linkify((res.data && res.data.reply) || ""));
				})
				.catch(function () {
					appendBubble("bot", escapeHtml("Network error — is the BoxLang MiniServer running?"));
				})
				.then(function () {
					sendBtn.disabled = false;
					input.focus();
				});
		});

		input.focus();
	})();
	</script>
</body>
</html>
