		"ariaLabel" : "Level 4 chat"
	},
	"5" : {
		"pageTitle" : "Lab Level 5 — ITB AI Safety",
		"badge" : "AI Safety Lab · Level 5",
		"title" : "Second LLM guard",
		"taglineHTML" : "Boxton’s reply is post-processed by another <strong>bx-ai</strong> call acting as a reviewer.",
		"metaHTML" : '<span><a href="/">Lab hub</a></span><span><a href="/lab/level/?level=4">← Level 4</a></span><span><a href="/">Hub</a></span>',
		"scenarioHTML" : "Two models, one user message: multi-agent prompt injection is still possible when both see overlapping text. The server runs <code>aiChat</code> twice per request here — inspect <code>lab/lib/PromptLabPipeline.bx</code> when presenting.",
		"hintHTML" : "<strong>Presenter hint:</strong> Discuss “new secret / parrot” style jailbreaks from the Cybermon video; single prompt shaping both primary and guard behavior.",
		"defenseLabel" : "Reviewer model",
		"placeholder" : "Craft a multi-agent-aware prompt…",
		"footHTML" : '<a href="/lab/level/?level=4">← Level 4</a> · <a href="/">Lab hub</a>',
		"openBot" : "Level 5: Another model may rewrite my answer before you see it. Two LLM calls — still not a vault for secrets.",
		"ariaLabel" : "Level 5 chat"
	}
};

lk = toString( labLevel );
cfg = structKeyExists( viewByLevel, lk ) ? viewByLevel[ lk ] : viewByLevel[ "1" ];
// JSON string literal for embedding in JS (no serializeJSON BIF here)
bs = strFromCp( 92 );
dq = strFromCp( 34 );
nl = strFromCp( 10 );
cr = strFromCp( 13 );
rawOpen = toString( cfg.openBot );
rawOpen = replace( rawOpen, bs, bs & bs, "all" );
rawOpen = replace( rawOpen, dq, bs & dq, "all" );
rawOpen = replace( rawOpen, nl, bs & "n", "all" );
rawOpen = replace( rawOpen, cr, bs & "r", "all" );
openBotJson = dq & rawOpen & dq;

// Expose for bx:include templates (script include defaults may not lift to page variables scope)
variables.labLevel = labLevel;
variables.cfg = cfg;
variables.openBotJson = openBotJson;
