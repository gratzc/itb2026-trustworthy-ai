<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>Into The Box 2026 — ITB Chat</title>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700;1,9..40,400&amp;family=Outfit:wght@600;700;800&amp;display=swap" rel="stylesheet" />
	<link rel="stylesheet" href="/static/itb-chat.css" />
</head>
<body>
	<div class="page">
		<header class="brand">
			<div class="brand-badge">Into The Box 2026</div>
			<h1>Modernization in Motion</h1>
			<p class="tagline">Building a dynamic future — <strong>ask the ITB guide anything.</strong></p>
			<div class="meta">
				<span>April 29 – May 1, 2026</span>
				<span>Washington, DC</span>
				<span><a href="https://www.intothebox.org/">intothebox.org</a></span>
			</div>
		</header>

		<section class="chat-shell" aria-label="Chat assistant">
			<div class="chat-head">
				<span class="chat-head-dot" aria-hidden="true"></span>
				<h2>ITB assistant</h2>
				<span>BoxLang + bx-ai</span>
			</div>
			<div id="messages" class="messages" role="log" aria-live="polite" aria-relevant="additions"></div>
			<form id="composer" class="composer" autocomplete="off">
				<input type="text" id="message" name="message" placeholder="Ask about the schedule, venue, BoxLang, registration…" maxlength="2000" required />
				<button type="submit" id="send">Send</button>
			</form>
		</section>

		<p class="foot">
			Demo chatbot for <a href="https://www.intothebox.org/">Into The Box</a> · presented by Ortus
		</p>
	</div>

	<script>
	(function () {
		var messagesEl = document.getElementById("messages");
		var form = document.getElementById("composer");
		var input = document.getElementById("message");
		var sendBtn = document.getElementById("send");

		function escapeHtml(s) {
			var div = document.createElement("div");
			div.textContent = s;
			return div.innerHTML;
		}

		function linkify(text) {
			var escaped = escapeHtml(text);
			return escaped.replace(/(https?:\/\/[^\s<]+)/g, function (url) {
				return '<a href="' + url + '" target="_blank" rel="noopener noreferrer">' + url + "</a>";
			});
		}

		function appendBubble(role, html) {
			var div = document.createElement("div");
			div.className = "msg " + role;
			var label = role === "bot" ? "ITB guide" : "You";
			div.innerHTML = '<div class="label">' + label + "</div><div class=\"body\">" + html + "</div>";
			messagesEl.appendChild(div);
			messagesEl.scrollTop = messagesEl.scrollHeight;
		}

		appendBubble("bot", linkify("Hi! I'm powered by the bx-ai module on BoxLang (Gemini), with an ITB-themed system prompt. Ask anything about Into The Box 2026 — dates, DC venue, registration, BoxLang, ColdBox, or sessions. (Without GEMINI_API_KEY in webroot/.env you will get short fallback answers.)"));

		form.addEventListener("submit", function (e) {
			e.preventDefault();
			var text = (input.value || "").trim();
			if (!text) return;

			appendBubble("user", escapeHtml(text));
			input.value = "";
			sendBtn.disabled = true;

			fetch("/api/chat.bxm", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ message: text })
			})
				.then(function (r) { return r.json().then(function (data) { return { ok: r.ok, data: data }; }); })
				.then(function (res) {
					if (!res.ok || (res.data && res.data.error)) {
						appendBubble("bot", escapeHtml((res.data && res.data.error) || "Something went wrong. Try again."));
						return;
					}
					appendBubble("bot", linkify((res.data && res.data.reply) || ""));
				})
				.catch(function () {
					appendBubble("bot", escapeHtml("Network error — is the BoxLang MiniServer running?"));
				})
				.then(function () {
					sendBtn.disabled = false;
					input.focus();
				});
		});

		input.focus();
	})();
	</script>
</body>
</html>
