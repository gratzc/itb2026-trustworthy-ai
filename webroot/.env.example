# MiniServer loads this automatically as webroot/.env
# https://boxlang.ortusbooks.com/getting-started/running-boxlang/miniserver
#
# AI provider is chosen in /.boxlang.json (repo root, git-ignored). See README.md.

# Required when .boxlang.json uses provider "gemini" with apiKey "${GEMINI_API_KEY}".
GEMINI_API_KEY=

# Optional: only if your tooling substitutes this into .boxlang.json defaultParams.model
# BXAI_MODEL=gemini-2.0-flash

# For local Ollama (provider "ollama" in .boxlang.json), leave GEMINI_API_KEY unset.
