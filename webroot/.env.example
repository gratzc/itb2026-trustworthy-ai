# MiniServer loads this automatically as webroot/.env
# https://boxlang.ortusbooks.com/getting-started/running-boxlang/miniserver

# Required for bx-ai (Gemini). Substituted into .boxlang.json as modules.bxai.settings.apiKey.
GEMINI_API_KEY=

# Optional: override Gemini model (default in .boxlang.json is gemini-2.0-flash)
# BXAI_MODEL=gemini-2.0-flash
